{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"],
      "#data/*": ["src/data/*"],
      "#utils/*": ["src/utils/*"],
      "#models/*": ["src/models/*"],
      "#routes/*": ["src/routes/*"],
      "#services/*": ["src/services/*"],
      "#controllers/*": ["src/controllers/*"],
      "#repositories/*": ["src/repositories/*"]
    }
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "eslint.config.js"]
}
