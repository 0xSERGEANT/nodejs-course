{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "#/*": ["src/*"],
      "#data/*": ["src/data/*"],
      "#utils/*": ["src/utils/*"],
      "#routes/*": ["src/routes/*"],
      "#controllers/*": ["src/controllers/*"]
    }
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "eslint.config.js"]
}
